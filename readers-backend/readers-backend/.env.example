# Podcast Index API credentials (free from podcastindex.org)
PODCAST_INDEX_KEY=your_free_key_from_podcastindex.org
PODCAST_INDEX_SECRET=your_free_secret_from_podcastindex.org

# Gemini API key (free from aistudio.google.com)
GEMINI_API_KEY=your_free_key_from_aistudio.google.com

# Firebase Service Account file path (optional, for auth validation/Firestore)
FIREBASE_SERVICE_ACCOUNT=path/to/serviceAccountKey.json

# CORS Allowed Origins (comma-separated list)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Backend Server Port
PORT=8000

CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
GEMINI_API_KEY="your-api-key-here"